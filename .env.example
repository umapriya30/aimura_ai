# =========================================================================
#  Aimura AI — reasoning provider chain
# =========================================================================
# The mentor and career intelligence work with ZERO keys (grounded offline
# guidance). Add keys to upgrade to live reasoning. The chain is tried in
# order: Microsoft Foundry IQ -> other providers -> deterministic offline.
# A provider that is missing, rate-limited, or out of credits is skipped
# automatically, so the app never breaks.

# -------------------------------------------------------------------------
# PRIMARY: Microsoft Foundry IQ (Azure AI Foundry)  [required for submission]
# -------------------------------------------------------------------------
# Create a free Azure AI Foundry resource, deploy a chat model (e.g. gpt-4o
# or gpt-4o-mini), then copy the endpoint, key, and deployment name here.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
# If your Azure portal/export uses this name instead, Aimura accepts it too.
AZURE_OPENAI_API_KEY=
AZURE_DEPLOYMENT_NAME=gpt-4o-mini
# These aliases are also accepted if your environment already uses them.
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# -------------------------------------------------------------------------
# FALLBACK reasoning providers (optional — used only if Foundry is unavailable)
# -------------------------------------------------------------------------
ANTHROPIC_API_KEY=
AIMURA_PRIMARY_MODEL=

OPENAI_API_KEY=
AIMURA_BACKUP_MODEL=gpt-4o-mini

# -------------------------------------------------------------------------
# Optional future provider slots. The app works without these keys.
# -------------------------------------------------------------------------
GROQ_API_KEY=
GEMINI_API_KEY=
TAVILY_API_KEY=
SERPAPI_API_KEY=
YOUTUBE_API_KEY=

# --- Local account activation ---
# Aimura shows activation and password reset links directly inside the app for
# demos, so no email provider or domain is required.
